{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "redirect/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/privacy", "dest": "/api/privacy.js" },
    { "src": "/robots.txt", "dest": "/api/robots.js" },
    { "src": "/sitemap.xml", "dest": "/api/sitemap.js" },
    { "src": "/favicon.svg", "dest": "/public/favicon.svg" },
    { "src": "/google4505ca1a3a4868b3.html", "dest": "/public/google4505ca1a3a4868b3.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/((?!api|privacy|robots|sitemap|favicon|google|_next)[^/]+)", "dest": "/redirect/[code].js" }
  ]
}
