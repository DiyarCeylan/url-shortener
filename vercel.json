{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/privacy", "destination": "/api/privacy.js" },
    { "source": "/robots.txt", "destination": "/api/robots.js" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.js" },
    { "source": "/favicon.svg", "destination": "/public/favicon.svg" },
    { "source": "/google4505ca1a3a4868b3.html", "destination": "/public/google4505ca1a3a4868b3.html" },
    { "source": "/((?!api|privacy|robots|sitemap|favicon|google)[^/]+)", "destination": "/redirect/[code].js" }
  ]
}
