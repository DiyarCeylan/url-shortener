{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/privacy", "dest": "/api/index.js" },
    { "src": "/robots.txt", "dest": "/api/index.js" },
    { "src": "/sitemap.xml", "dest": "/api/index.js" },
    { "src": "/favicon.svg", "dest": "/public/favicon.svg" },
    { "src": "/google4505ca1a3a4868b3.html", "dest": "/public/google4505ca1a3a4868b3.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/((?!api|favicon|google|_next)[^/]+)", "dest": "/api/index.js" }
  ]
}
